{
  "name": "rsqlite-wasm",
  "version": "0.1.0",
  "description": "SQLite-compatible database for the browser, powered by Rust and WebAssembly",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "default": "./dist/worker.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:wasm": "cd .. && wasm-pack build --target web --release --out-dir ../../js/dist/wasm --no-pack crates/rsqlite-wasm && rm -f js/dist/wasm/.gitignore",
    "build:ts": "tsc",
    "build:meta": "cp ../README.md README.md && cp ../LICENSE LICENSE",
    "build": "npm run clean && npm run build:wasm && npm run build:ts && npm run build:meta",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sqlite",
    "wasm",
    "webassembly",
    "database",
    "sql",
    "browser",
    "pwa",
    "indexeddb",
    "opfs"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nightness/rsqlite-wasm.git",
    "directory": "js"
  },
  "homepage": "https://github.com/nightness/rsqlite-wasm#readme",
  "bugs": {
    "url": "https://github.com/nightness/rsqlite-wasm/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4"
  }
}
